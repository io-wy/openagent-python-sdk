{
  "version": "1.0",
  "logging": {
    "auto_configure": true,
    "pretty": true,
    "level": "INFO"
  },
  "events": {
    "type": "rich_console",
    "config": {
      "inner": { "type": "async" },
      "show_payload": true,
      "stream": "stderr"
    }
  },
  "runtime": {
    "type": "default",
    "config": {
      "tool_executor": {
        "type": "safe",
        "config": {
          "default_timeout_ms": 60000
        }
      }
    }
  },
  "agents": [
    {
      "id": "llm-wiki-agent",
      "name": "LLM Wiki Agent",
      "memory": {
        "type": "chain",
        "on_error": "continue",
        "config": {
          "memories": [
            {
              "type": "window_buffer",
              "config": {
                "window_size": 8
              }
            },
            {
              "impl": "examples.llm_wiki_agent.app.plugins.WikiMemory",
              "config": {
                "storage_dir": "examples/llm_wiki_agent/knowledge",
                "session_dir": "examples/llm_wiki_agent/sessions"
              }
            }
          ]
        }
      },
      "pattern": {
        "impl": "examples.llm_wiki_agent.app.plugins.WikiPattern",
        "config": {
          "max_steps": 10,
          "chunk_size": 2000
        }
      },
      "context_assembler": {
        "impl": "examples.llm_wiki_agent.app.plugins.WikiContextAssembler",
        "config": {
          "knowledge_dir": "examples/llm_wiki_agent/knowledge"
        }
      },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0.2,
        "max_tokens": 4096,
        "timeout_ms": 60000
      },
      "tool_executor": {
        "type": "safe",
        "config": {
          "command_allowlist": ["opencli"],
          "default_timeout_ms": 120000
        }
      },
      "tools": [
        { "id": "ingest_url", "impl": "examples.llm_wiki_agent.app.plugins.IngestUrlTool", "config": { "storage_dir": "examples/llm_wiki_agent/knowledge", "chunk_size": 2000 } },
        { "id": "deep_read_url", "impl": "examples.llm_wiki_agent.app.plugins.DeepReadUrlTool", "config": { "timeout_seconds": 60 } },
        { "id": "search_kb", "impl": "examples.llm_wiki_agent.app.plugins.SearchKbTool", "config": { "storage_dir": "examples/llm_wiki_agent/knowledge" } },
        { "id": "list_sources", "impl": "examples.llm_wiki_agent.app.plugins.ListSourcesTool", "config": { "storage_dir": "examples/llm_wiki_agent/knowledge" } }
      ],
      "runtime": {
        "max_steps": 10,
        "step_timeout_ms": 120000,
        "session_queue_size": 1000,
        "event_queue_size": 2000
      }
    }
  ]
}

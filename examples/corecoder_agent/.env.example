# Copy to .env and fill in your provider details.
# CoreCoder uses an Anthropic-compatible endpoint (Messages API + tool_use).

LLM_API_BASE=https://api.anthropic.com
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5-20250929

# MiniMax also exposes an Anthropic-compatible endpoint and works out of the box:
# LLM_API_BASE=https://api.minimaxi.com/anthropic
# LLM_API_KEY=...
# LLM_MODEL=MiniMax-M1

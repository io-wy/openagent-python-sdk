# Copy to .env and fill in one provider block.

# Anthropic-compatible endpoint (default provider if omitted):
LLM_PROVIDER=anthropic
LLM_API_BASE=https://api.anthropic.com
LLM_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5-20250929

# OpenAI-compatible Chat Completions:
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4.1-mini
# LLM_OPENAI_API_STYLE=chat_completions

# If you already keep OpenAI-style names in .env, run_demo.py will alias them:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini

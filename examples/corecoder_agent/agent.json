{
  "version": "1.0",
  "logging": {
    "auto_configure": true,
    "pretty": true,
    "level": "INFO",
    "per_logger_levels": {
      "openagents.llm": "INFO",
      "openagents.events": "WARNING",
      "openagents.session": "WARNING"
    },
    "include_prefixes": ["openagents"],
    "redact_keys": ["api_key", "authorization", "token", "secret", "password", "cookie"],
    "max_value_length": 400
  },
  "events": {
    "type": "rich_console",
    "config": {
      "inner": { "type": "async" },
      "show_payload": true,
      "stream": "stderr"
    }
  },
  "runtime": {
    "type": "default",
    "config": {
      "tool_executor": {
        "type": "safe",
        "config": {
          "default_timeout_ms": 60000
        }
      }
    }
  },
  "agents": [
    {
      "id": "corecoder",
      "name": "CoreCoder",
      "memory": {
        "type": "chain",
        "on_error": "continue",
        "config": {
          "memories": [
            {
              "impl": "examples.corecoder_agent.app.memory.CoreCoderMemory",
              "config": {
                "storage_dir": "examples/corecoder_agent/.agent_memory",
                "max_summaries": 10
              }
            }
          ]
        }
      },
      "pattern": {
        "impl": "examples.corecoder_agent.app.pattern.CoreCoderPattern",
        "config": {
          "max_steps": 20,
          "max_tokens": 4096,
          "temperature": 0.1
        }
      },
      "context_assembler": {
        "impl": "examples.corecoder_agent.app.context.CompressingContextAssembler",
        "config": {
          "max_input_tokens": 16000,
          "reserve_for_response": 4096,
          "snip_threshold": 0.5,
          "summarize_threshold": 0.7,
          "hard_collapse_threshold": 0.9,
          "tool_output_max_bytes": 2000,
          "tool_output_keep_head": 1000,
          "tool_output_keep_tail": 500,
          "keep_recent_messages_for_summary": 10,
          "keep_first_messages": 2,
          "keep_last_messages_on_collapse": 5,
          "max_artifacts": 10,
          "summary_max_words": 200
        }
      },
      "llm": {
        "provider": "${LLM_PROVIDER:-anthropic}",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "${LLM_API_KEY_ENV:-LLM_API_KEY}",
        "model": "${LLM_MODEL}",
        "openai_api_style": "${LLM_OPENAI_API_STYLE:-chat_completions}",
        "temperature": 0.1,
        "max_tokens": 4096,
        "timeout_ms": 120000
      },
      "tools": [
        {
          "id": "read_file",
          "impl": "examples.corecoder_agent.app.tools.read_file.ReadFileTool"
        },
        {
          "id": "write_file",
          "impl": "examples.corecoder_agent.app.tools.write_file.WriteFileTool"
        },
        {
          "id": "edit_file",
          "impl": "examples.corecoder_agent.app.tools.edit_file.EditFileTool"
        },
        {
          "id": "glob",
          "impl": "examples.corecoder_agent.app.tools.glob_tool.GlobTool"
        },
        {
          "id": "grep",
          "impl": "examples.corecoder_agent.app.tools.grep_tool.GrepTool"
        },
        {
          "id": "bash",
          "impl": "examples.corecoder_agent.app.tools.bash_tool.BashTool"
        },
        {
          "id": "sub_agent",
          "impl": "examples.corecoder_agent.app.tools.sub_agent.SubAgentTool",
          "config": {
            "agent_config_path": "examples/corecoder_agent/agent.json",
            "sub_agent_id": "corecoder-subagent",
            "max_output_chars": 5000
          }
        }
      ],
      "runtime": {
        "max_steps": 30,
        "step_timeout_ms": 600000,
        "session_queue_size": 1000,
        "event_queue_size": 4000
      }
    },
    {
      "id": "corecoder-subagent",
      "name": "CoreCoder Sub-agent",
      "memory": {
        "type": "window_buffer",
        "config": {
          "window_size": 12
        }
      },
      "pattern": {
        "impl": "examples.corecoder_agent.app.pattern.CoreCoderPattern",
        "config": {
          "max_steps": 12,
          "max_tokens": 4096,
          "temperature": 0.1
        }
      },
      "context_assembler": {
        "impl": "examples.corecoder_agent.app.context.CompressingContextAssembler",
        "config": {
          "max_input_tokens": 12000,
          "reserve_for_response": 3000,
          "snip_threshold": 0.5,
          "summarize_threshold": 0.7,
          "hard_collapse_threshold": 0.9
        }
      },
      "llm": {
        "provider": "${LLM_PROVIDER:-anthropic}",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "${LLM_API_KEY_ENV:-LLM_API_KEY}",
        "model": "${LLM_MODEL}",
        "openai_api_style": "${LLM_OPENAI_API_STYLE:-chat_completions}",
        "temperature": 0.1,
        "max_tokens": 4096,
        "timeout_ms": 120000
      },
      "tools": [
        {
          "id": "read_file",
          "impl": "examples.corecoder_agent.app.tools.read_file.ReadFileTool"
        },
        {
          "id": "write_file",
          "impl": "examples.corecoder_agent.app.tools.write_file.WriteFileTool"
        },
        {
          "id": "edit_file",
          "impl": "examples.corecoder_agent.app.tools.edit_file.EditFileTool"
        },
        {
          "id": "glob",
          "impl": "examples.corecoder_agent.app.tools.glob_tool.GlobTool"
        },
        {
          "id": "grep",
          "impl": "examples.corecoder_agent.app.tools.grep_tool.GrepTool"
        },
        {
          "id": "bash",
          "impl": "examples.corecoder_agent.app.tools.bash_tool.BashTool"
        }
      ],
      "runtime": {
        "max_steps": 20,
        "step_timeout_ms": 300000
      }
    }
  ]
}

{
  "version": "1.0",
  "multi_agent": {
    "enabled": true,
    "default_session_isolation": "isolated",
    "max_delegation_depth": 3
  },
  "events": {
    "type": "rich_console",
    "config": {
      "inner": { "type": "async" },
      "include_events": ["tool.called", "tool.succeeded", "llm.succeeded", "session.run.started", "session.run.completed"],
      "show_payload": false,
      "redact_keys": ["api_key", "authorization"]
    }
  },
  "logging": {
    "auto_configure": true,
    "pretty": true,
    "level": "INFO",
    "redact_keys": ["api_key", "authorization", "token"],
    "max_value_length": 300
  },
  "agents": [
    {
      "id": "orchestrator",
      "name": "Orchestrator",
      "memory": { "type": "window_buffer", "config": { "window_size": 20 } },
      "pattern": { "type": "react", "config": { "max_steps": 4 } },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0
      },
      "tools": [
        {
          "id": "delegate_to_specialist",
          "impl": "examples.multi_agent.plugins.DelegateToSpecialistTool"
        }
      ]
    },
    {
      "id": "triage",
      "name": "Triage",
      "memory": { "type": "window_buffer", "config": { "window_size": 20 } },
      "pattern": { "type": "react", "config": { "max_steps": 3 } },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0
      },
      "tools": [
        {
          "id": "transfer_to_billing",
          "impl": "examples.multi_agent.plugins.TransferToBillingTool"
        }
      ]
    },
    {
      "id": "specialist",
      "name": "Specialist",
      "memory": { "type": "buffer" },
      "pattern": { "type": "react", "config": { "max_steps": 2 } },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0
      }
    },
    {
      "id": "billing_agent",
      "name": "Billing",
      "memory": { "type": "buffer" },
      "pattern": { "type": "react", "config": { "max_steps": 2 } },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0
      }
    }
  ]
}

{
  "version": "1.0",
  "logging": {
    "auto_configure": true,
    "pretty": true,
    "level": "INFO"
  },
  "agents": [
    {
      "id": "assistant",
      "name": "demo-agent",
      "memory": {
        "type": "window_buffer",
        "config": {
          "window_size": 20
        },
        "on_error": "continue"
      },
      "pattern": {
        "type": "react",
        "config": {
          "max_steps": 8
        }
      },
      "llm": {
        "provider": "anthropic",
        "api_base": "${LLM_API_BASE}",
        "api_key_env": "LLM_API_KEY",
        "model": "${LLM_MODEL}",
        "temperature": 0
      },
      "tools": [
        {
          "id": "search",
          "type": "builtin_search",
          "enabled": true,
          "config": {}
        }
      ],
      "runtime": {
        "max_steps": 16,
        "step_timeout_ms": 30000,
        "session_queue_size": 1000,
        "event_queue_size": 2000
      }
    }
  ]
}
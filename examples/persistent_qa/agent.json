{
  "version": "1.0",
  "runtime": {
    "type": "default"
  },
  "session": {
    "type": "in_memory"
  },
  "events": {
    "type": "async"
  },
  "agents": [
    {
      "id": "qa_assistant",
      "name": "Comprehensive QA Assistant",
      "enabled": true,
      "memory": {
        "type": "chain",
        "config": {
          "memories": [
            {
              "type": "window_buffer",
              "config": {
                "window_size": 10
              }
            }
          ]
        }
      },
      "pattern": {
        "type": "react",
        "config": {
          "max_steps": 5,
          "step_timeout_ms": 30000
        }
      },
      "llm": {
        "provider": "openai_compatible",
        "model": "LongCat-Flash-Chat",
        "api_base": "https://api.longcat.chat/openai/v1",
        "api_key_env": "LONGCAT_API_KEY",
        "temperature": 0.7,
        "max_tokens": 2048,
        "timeout_ms": 60000
      },
      "tools": [
        {
          "id": "search",
          "type": "builtin_search",
          "enabled": true,
          "config": {}
        },
        {
          "id": "calculator",
          "type": "calc",
          "enabled": true,
          "config": {}
        },
        {
          "id": "current_time",
          "type": "current_time",
          "enabled": true,
          "config": {}
        },
        {
          "id": "date_parse",
          "type": "date_parse",
          "enabled": true,
          "config": {}
        },
        {
          "id": "random_int",
          "type": "random_int",
          "enabled": true,
          "config": {
            "min": 1,
            "max": 100
          }
        },
        {
          "id": "uuid_gen",
          "type": "uuid",
          "enabled": true,
          "config": {}
        },
        {
          "id": "url_parse",
          "type": "url_parse",
          "enabled": true,
          "config": {}
        },
        {
          "id": "json_parse",
          "type": "json_parse",
          "enabled": true,
          "config": {}
        },
        {
          "id": "read_file",
          "type": "read_file",
          "enabled": true,
          "config": {}
        },
        {
          "id": "list_files",
          "type": "list_files",
          "enabled": true,
          "config": {}
        }
      ]
    }
  ]
}
